{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-frontmatter.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "ship-executor|ship-verifier",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-agent-completion.js\""
          }
        ]
      }
    ]
  }
}
