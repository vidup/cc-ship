{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-frontmatter.js"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "ship-executor|ship-verifier",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-agent-completion.js"
          }
        ]
      }
    ]
  }
}
